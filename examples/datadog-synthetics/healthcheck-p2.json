{
  "name": "{{SITE_NAME}} – API Healthcheck (P2 High)",
  "status": "live",
  "type": "api",
  "subtype": "multi",
  "tags": ["{{SITE_TAG}}", "healthcheck", "watchtower", "p2"],
  "config": {
    "configVariables": [],
    "steps": [
      {
        "name": "Hit /api/healthcheck route — assert status Up",
        "subtype": "http",
        "extractedValues": [
          {
            "type": "http_body",
            "parser": { "type": "raw" },
            "name": "RESPONSE_BODY",
            "secure": false
          }
        ],
        "allowFailure": false,
        "isCritical": true,
        "retry": {
          "count": 0,
          "interval": 300
        },
        "assertions": [
          {
            "type": "body",
            "operator": "validatesJSONPath",
            "target": {
              "jsonPath": "status",
              "operator": "is",
              "targetValue": "Up"
            }
          },
          {
            "operator": "is",
            "type": "statusCode",
            "target": 200
          },
          {
            "operator": "is",
            "property": "content-type",
            "type": "header",
            "target": "application/json; charset=utf-8"
          }
        ],
        "request": {
          "method": "GET",
          "url": "{{SITE_URL}}/api/healthcheck",
          "headers": {
            "X-Healthcheck-Token": "{{HEALTHCHECK_TOKEN}}"
          },
          "httpVersion": "any"
        }
      }
    ]
  },
  "message": "{{SITE_NAME}} – API Healthcheck (P2 High)\n\n{{#is_alert}}\n⚠️ _{{SITE_NAME}} healthcheck is reporting degraded service (`Partial` status)._\n\nThe site is responding but one or more checks are failing. Investigate.\n\nView full breakdown: {{SITE_URL}}/api/healthcheck/test\n{{/is_alert}}\n\n{{#is_recovery}}\n✅ _{{SITE_NAME}} healthcheck is back to fully healthy._ Close any open tickets.\n{{/is_recovery}}\n\n@slack-uptime-monitoring @jira-support-issue",
  "options": {
    "min_failure_duration": 300,
    "monitor_name": "{{SITE_NAME}} – Degraded Service (P2)",
    "monitor_options": {
      "notification_preset_name": "show_all"
    },
    "monitor_priority": 2,
    "retry": {
      "count": 1,
      "interval": 180000
    },
    "tick_every": 300,
    "min_location_failed": 1
  },
  "locations": ["aws:us-east-2", "azure:eastus"]
}
