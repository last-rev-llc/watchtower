{
  "name": "{{SITE_NAME}} – API Healthcheck (P1 Critical)",
  "status": "live",
  "type": "api",
  "subtype": "multi",
  "tags": ["{{SITE_TAG}}", "healthcheck", "watchtower", "p1"],
  "config": {
    "configVariables": [],
    "steps": [
      {
        "name": "Hit /api/healthcheck route — assert HTTP 200",
        "subtype": "http",
        "extractedValues": [
          {
            "type": "http_body",
            "parser": { "type": "raw" },
            "name": "RESPONSE_BODY",
            "secure": false
          }
        ],
        "allowFailure": false,
        "isCritical": true,
        "retry": {
          "count": 1,
          "interval": 300
        },
        "assertions": [
          {
            "operator": "is",
            "type": "statusCode",
            "target": 200
          }
        ],
        "request": {
          "method": "GET",
          "url": "{{SITE_URL}}/api/healthcheck",
          "headers": {
            "X-Healthcheck-Token": "{{HEALTHCHECK_TOKEN}}"
          },
          "httpVersion": "any"
        }
      }
    ]
  },
  "message": "{{SITE_NAME}} – API Healthcheck (P1 Critical)\n\n{{#is_alert}}\n🚨 _{{SITE_NAME}} is reporting a **full outage** (HTTP 503 — `Down` or `Unknown`)._\n\nThis is a P1 Critical incident. Escalate immediately.\n\nView full breakdown: {{SITE_URL}}/api/healthcheck/test\n{{/is_alert}}\n\n{{#is_recovery}}\n✅ _{{SITE_NAME}} is back online._ The issue has been resolved. Please notify the team and close any open tickets.\n{{/is_recovery}}\n\n@slack-uptime-monitoring @jira-support-issue",
  "options": {
    "min_failure_duration": 300,
    "monitor_name": "{{SITE_NAME}} – Full Outage (P1)",
    "monitor_options": {
      "notification_preset_name": "show_all"
    },
    "monitor_priority": 1,
    "retry": {
      "count": 1,
      "interval": 60000
    },
    "tick_every": 60,
    "min_location_failed": 1
  },
  "locations": ["aws:us-east-2", "azure:eastus"]
}
